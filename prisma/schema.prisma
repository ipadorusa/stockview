generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  nickname      String?   @unique
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  role          UserRole       @default(USER)
  accounts      Account[]
  sessions      Session[]
  watchlist     Watchlist[]
  portfolio     Portfolio[]
  boardPosts      BoardPost[]      @relation("UserBoardPosts")
  boardComments   BoardComment[]   @relation("UserBoardComments")
  reportRequests  ReportRequest[]  @relation("UserReportRequests")
  requestComments RequestComment[] @relation("UserRequestComments")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Stock {
  id        String   @id @default(cuid())
  ticker    String   @unique
  name      String
  nameEn    String?
  market    Market
  exchange  String
  sector    String?
  sectorId  String?
  stockType StockType @default(STOCK)
  corpCode  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sectorRef           Sector?  @relation(fields: [sectorId], references: [id])
  quotes              StockQuote[]
  dailyPrices         DailyPrice[]
  watchlist           Watchlist[]
  portfolio           Portfolio[]
  news                StockNews[]
  fundamental         StockFundamental?
  fundamentalHistory  FundamentalHistory[]

  dividends           Dividend[]
  earningsEvents      EarningsEvent[]
  disclosures         Disclosure[]
  aiReports           AiReport[]
  reportRequests      ReportRequest[]
  institutionalFlows  InstitutionalFlow[]

  @@index([market])
  @@index([market, isActive])
  @@index([name])
  @@index([sector])
  @@index([sectorId])
  @@index([stockType])
}

enum Market {
  KR
  US
}

enum UserRole {
  USER
  ADMIN
}

enum StockType {
  STOCK
  ETF
}

model StockQuote {
  id              String   @id @default(cuid())
  stockId         String   @unique
  price           Decimal  @db.Decimal(18, 4)
  previousClose   Decimal  @db.Decimal(18, 4)
  change          Decimal  @db.Decimal(18, 4)
  changePercent   Decimal  @db.Decimal(10, 4)
  open            Decimal  @db.Decimal(18, 4)
  high            Decimal  @db.Decimal(18, 4)
  low             Decimal  @db.Decimal(18, 4)
  volume          BigInt
  marketCap       BigInt?
  high52w         Decimal? @db.Decimal(18, 4)
  low52w          Decimal? @db.Decimal(18, 4)
  per             Decimal? @db.Decimal(10, 2)
  pbr             Decimal? @db.Decimal(10, 2)
  preMarketPrice  Decimal? @db.Decimal(18, 4)
  postMarketPrice Decimal? @db.Decimal(18, 4)
  updatedAt       DateTime @updatedAt

  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@index([updatedAt])
}

model DailyPrice {
  id       String   @id @default(cuid())
  stockId  String
  date     DateTime @db.Date
  open     Decimal  @db.Decimal(18, 4)
  high     Decimal  @db.Decimal(18, 4)
  low      Decimal  @db.Decimal(18, 4)
  close    Decimal  @db.Decimal(18, 4)
  volume   BigInt
  adjClose Decimal? @db.Decimal(18, 4)

  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([stockId, date])
  @@index([stockId, date])
}

model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  stockId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([userId, stockId])
  @@index([userId])
}

model Portfolio {
  id        String   @id @default(cuid())
  userId    String
  stockId   String
  buyPrice  Decimal  @db.Decimal(18, 4)
  quantity  Int
  buyDate   DateTime? @db.Date
  memo      String?
  groupName String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([userId, stockId])
  @@index([userId])
}

model News {
  id          String       @id @default(cuid())
  title       String
  summary     String?      @db.Text
  content     String?      @db.Text  // 기사 본문 첫 300자 (저작권 주의)
  source      String
  url         String       @unique
  imageUrl    String?
  category    NewsCategory
  sentiment   String?
  publishedAt DateTime
  createdAt   DateTime     @default(now())

  stocks StockNews[]

  @@index([publishedAt])
  @@index([category])
}

model StockNews {
  stockId String
  newsId  String

  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)
  news  News  @relation(fields: [newsId], references: [id], onDelete: Cascade)

  @@id([stockId, newsId])
  @@index([newsId])
}

enum NewsCategory {
  KR_MARKET
  US_MARKET
  INDUSTRY
  ECONOMY
}

model MarketIndex {
  id            String   @id @default(cuid())
  symbol        String   @unique
  name          String
  value         Decimal  @db.Decimal(18, 4)
  change        Decimal  @db.Decimal(18, 4)
  changePercent Decimal  @db.Decimal(10, 4)
  updatedAt     DateTime @updatedAt

  history MarketIndexHistory[]
}

model MarketIndexHistory {
  id            String   @id @default(cuid())
  symbol        String
  date          DateTime @db.Date
  open          Decimal? @db.Decimal(18, 4)
  high          Decimal? @db.Decimal(18, 4)
  low           Decimal? @db.Decimal(18, 4)
  close         Decimal  @db.Decimal(18, 4)
  change        Decimal  @db.Decimal(18, 4)
  changePercent Decimal  @db.Decimal(10, 4)
  volume        BigInt?
  createdAt     DateTime @default(now())

  index MarketIndex @relation(fields: [symbol], references: [symbol], onDelete: Cascade)

  @@unique([symbol, date])
  @@index([symbol, date])
}

model ExchangeRate {
  id            String   @id @default(cuid())
  pair          String   @unique
  rate          Decimal  @db.Decimal(18, 4)
  change        Decimal  @db.Decimal(18, 4)
  changePercent Decimal  @db.Decimal(10, 4)
  updatedAt     DateTime @updatedAt
}

model StockFundamental {
  id            String   @id @default(cuid())
  stockId       String   @unique
  eps           Decimal? @db.Decimal(18, 4)
  forwardEps    Decimal? @db.Decimal(18, 4)
  dividendYield Decimal? @db.Decimal(10, 4)
  roe           Decimal? @db.Decimal(10, 4)
  debtToEquity  Decimal? @db.Decimal(10, 4)
  beta          Decimal? @db.Decimal(10, 4)
  revenue       BigInt?
  netIncome     BigInt?
  description   String?  @db.Text
  employeeCount Int?
  updatedAt     DateTime @updatedAt
  stock         Stock    @relation(fields: [stockId], references: [id], onDelete: Cascade)
}

model FundamentalHistory {
  id              String   @id @default(cuid())
  stockId         String
  quarter         String   // e.g. "2026Q1"
  eps             Decimal? @db.Decimal(18, 4)
  forwardEps      Decimal? @db.Decimal(18, 4)
  dividendYield   Decimal? @db.Decimal(10, 4)
  roe             Decimal? @db.Decimal(10, 4)
  debtToEquity    Decimal? @db.Decimal(10, 4)
  beta            Decimal? @db.Decimal(10, 4)
  revenue         BigInt?
  netIncome       BigInt?
  operatingIncome BigInt?
  createdAt       DateTime @default(now())

  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([stockId, quarter])
  @@index([stockId])
  @@index([quarter])
}


model Dividend {
  id            String    @id @default(cuid())
  stockId       String
  exDate        DateTime  @db.Date
  payDate       DateTime? @db.Date
  amount        Decimal   @db.Decimal(18, 4)
  currency      String    @default("KRW")
  dividendYield Decimal?  @db.Decimal(10, 4)
  payoutRatio   Decimal?  @db.Decimal(10, 4)
  faceValue     Decimal?  @db.Decimal(18, 4)
  source        String?
  stock         Stock     @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([stockId, exDate])
}

model Disclosure {
  id         String   @id @default(cuid())
  stockId    String
  rceptNo    String   @unique
  reportName String
  filerName  String?
  rceptDate  DateTime @db.Date
  remark     String?
  createdAt  DateTime @default(now())
  stock      Stock    @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@index([stockId, rceptDate])
  @@index([rceptDate])
}

model CronLog {
  id              String   @id @default(cuid())
  jobName         String
  status          String   // "success" | "error" | "partial"
  duration        Int      // ms
  itemsProcessed  Int?
  itemsFailed     Int?
  details         String?  @db.Text
  createdAt       DateTime @default(now())

  @@index([jobName])
  @@index([createdAt])
}

model EarningsEvent {
  id              String   @id @default(cuid())
  stockId         String
  reportDate      DateTime @db.Date
  quarter         String
  epsEstimate     Decimal? @db.Decimal(18, 4)
  epsActual       Decimal? @db.Decimal(18, 4)
  revenueEstimate BigInt?
  revenueActual   BigInt?
  updatedAt       DateTime @updatedAt
  stock           Stock    @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([stockId, quarter])
}

model AiReport {
  id           String   @id @default(cuid())
  slug         String   @unique
  stockId      String
  stock        Stock    @relation(fields: [stockId], references: [id], onDelete: Cascade)
  title        String   @db.Text
  signal       String
  content      String   @db.Text
  summary      String   @db.Text
  verdict      String
  reportDate   DateTime @db.Date
  dataSnapshot Json
  model        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  reportRequests ReportRequest[]

  @@unique([stockId, reportDate])
  @@index([createdAt])
  @@index([signal])
  @@index([stockId])
}

model BoardPost {
  id        String   @id @default(cuid())
  title     String   @db.VarChar(200)
  content   String   @db.Text
  authorId  String
  isPrivate Boolean  @default(true)
  viewCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author   User           @relation("UserBoardPosts", fields: [authorId], references: [id], onDelete: Cascade)
  comments BoardComment[]

  @@index([authorId])
  @@index([createdAt])
}

model BoardComment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  authorId  String
  postId    String
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author  User           @relation("UserBoardComments", fields: [authorId], references: [id], onDelete: Cascade)
  post    BoardPost      @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent  BoardComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies BoardComment[] @relation("CommentReplies")

  @@index([postId, createdAt])
  @@index([parentId])
  @@index([authorId])
}

model Sector {
  id        String   @id @default(cuid())
  name      String
  market    Market
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stocks Stock[]

  @@unique([name, market])
  @@index([market])
}

model InstitutionalFlow {
  id              Int      @id @default(autoincrement())
  stockId         String
  date            DateTime @db.Date
  foreignBuy      BigInt   @default(0)
  foreignSell     BigInt   @default(0)
  foreignNet      BigInt   @default(0)
  institutionBuy  BigInt   @default(0)
  institutionSell BigInt   @default(0)
  institutionNet  BigInt   @default(0)
  stock           Stock    @relation(fields: [stockId], references: [id])

  @@unique([stockId, date])
  @@index([stockId])
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  GENERATING
  COMPLETED
  FAILED
}

model ReportRequest {
  id          String        @id @default(cuid())
  userId      String
  stockId     String
  ticker      String
  status      RequestStatus @default(PENDING)
  requestedAt DateTime      @default(now())
  approvedAt  DateTime?
  completedAt DateTime?
  aiReportId  String?

  user     User             @relation("UserReportRequests", fields: [userId], references: [id], onDelete: Cascade)
  stock    Stock            @relation(fields: [stockId], references: [id], onDelete: Cascade)
  aiReport AiReport?        @relation(fields: [aiReportId], references: [id], onDelete: SetNull)
  comments RequestComment[]

  @@index([status])
  @@index([userId])
  @@index([stockId])
}

model RequestComment {
  id        String   @id @default(cuid())
  requestId String
  userId    String
  content   String   @db.Text
  createdAt DateTime @default(now())

  request ReportRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user    User          @relation("UserRequestComments", fields: [userId], references: [id], onDelete: Cascade)

  @@index([requestId, createdAt])
  @@index([userId])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  category  String
  message   String   @db.Text
  createdAt DateTime @default(now())

  @@index([createdAt])
}
