generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  password      String
  nickname      String    @unique
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  watchlist Watchlist[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Stock {
  id        String   @id @default(cuid())
  ticker    String   @unique
  name      String
  nameEn    String?
  market    Market
  exchange  String
  sector    String?
  stockType StockType @default(STOCK)
  corpCode  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quotes              StockQuote[]
  dailyPrices         DailyPrice[]
  watchlist           Watchlist[]
  news                StockNews[]
  fundamental         StockFundamental?
  technicalIndicators TechnicalIndicator[]
  dividends           Dividend[]
  earningsEvents      EarningsEvent[]
  disclosures         Disclosure[]
  aiReports           AiReport[]

  @@index([market])
  @@index([market, isActive])
  @@index([name])
  @@index([sector])
  @@index([stockType])
}

enum Market {
  KR
  US
}

enum StockType {
  STOCK
  ETF
}

model StockQuote {
  id              String   @id @default(cuid())
  stockId         String   @unique
  price           Decimal  @db.Decimal(18, 4)
  previousClose   Decimal  @db.Decimal(18, 4)
  change          Decimal  @db.Decimal(18, 4)
  changePercent   Decimal  @db.Decimal(10, 4)
  open            Decimal  @db.Decimal(18, 4)
  high            Decimal  @db.Decimal(18, 4)
  low             Decimal  @db.Decimal(18, 4)
  volume          BigInt
  marketCap       BigInt?
  high52w         Decimal? @db.Decimal(18, 4)
  low52w          Decimal? @db.Decimal(18, 4)
  per             Decimal? @db.Decimal(10, 2)
  pbr             Decimal? @db.Decimal(10, 2)
  preMarketPrice  Decimal? @db.Decimal(18, 4)
  postMarketPrice Decimal? @db.Decimal(18, 4)
  updatedAt       DateTime @updatedAt

  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@index([updatedAt])
}

model DailyPrice {
  id       String   @id @default(cuid())
  stockId  String
  date     DateTime @db.Date
  open     Decimal  @db.Decimal(18, 4)
  high     Decimal  @db.Decimal(18, 4)
  low      Decimal  @db.Decimal(18, 4)
  close    Decimal  @db.Decimal(18, 4)
  volume   BigInt
  adjClose Decimal? @db.Decimal(18, 4)

  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([stockId, date])
  @@index([stockId, date])
}

model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  stockId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([userId, stockId])
  @@index([userId])
}

model News {
  id          String       @id @default(cuid())
  title       String
  summary     String?      @db.Text
  content     String?      @db.Text  // 기사 본문 첫 300자 (저작권 주의)
  source      String
  url         String       @unique
  imageUrl    String?
  category    NewsCategory
  sentiment   String?
  publishedAt DateTime
  createdAt   DateTime     @default(now())

  stocks StockNews[]

  @@index([publishedAt])
  @@index([category])
}

model StockNews {
  stockId String
  newsId  String

  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)
  news  News  @relation(fields: [newsId], references: [id], onDelete: Cascade)

  @@id([stockId, newsId])
  @@index([newsId])
}

enum NewsCategory {
  KR_MARKET
  US_MARKET
  INDUSTRY
  ECONOMY
}

model MarketIndex {
  id            String   @id @default(cuid())
  symbol        String   @unique
  name          String
  value         Decimal  @db.Decimal(18, 4)
  change        Decimal  @db.Decimal(18, 4)
  changePercent Decimal  @db.Decimal(10, 4)
  updatedAt     DateTime @updatedAt
}

model ExchangeRate {
  id            String   @id @default(cuid())
  pair          String   @unique
  rate          Decimal  @db.Decimal(18, 4)
  change        Decimal  @db.Decimal(18, 4)
  changePercent Decimal  @db.Decimal(10, 4)
  updatedAt     DateTime @updatedAt
}

model StockFundamental {
  id            String   @id @default(cuid())
  stockId       String   @unique
  eps           Decimal? @db.Decimal(18, 4)
  forwardEps    Decimal? @db.Decimal(18, 4)
  dividendYield Decimal? @db.Decimal(10, 4)
  roe           Decimal? @db.Decimal(10, 4)
  debtToEquity  Decimal? @db.Decimal(10, 4)
  beta          Decimal? @db.Decimal(10, 4)
  revenue       BigInt?
  netIncome     BigInt?
  description   String?  @db.Text
  employeeCount Int?
  updatedAt     DateTime @updatedAt
  stock         Stock    @relation(fields: [stockId], references: [id], onDelete: Cascade)
}

model TechnicalIndicator {
  id            String   @id @default(cuid())
  stockId       String
  date          DateTime @db.Date
  ma5           Decimal? @db.Decimal(18, 4)
  ma20          Decimal? @db.Decimal(18, 4)
  ma60          Decimal? @db.Decimal(18, 4)
  ema12         Decimal? @db.Decimal(18, 4)
  ema26         Decimal? @db.Decimal(18, 4)
  rsi14         Decimal? @db.Decimal(10, 4)
  avgVolume20   BigInt?
  macdLine      Decimal? @db.Decimal(18, 4)
  macdSignal    Decimal? @db.Decimal(18, 4)
  macdHistogram Decimal? @db.Decimal(18, 4)
  bbUpper       Decimal? @db.Decimal(18, 4)
  bbMiddle      Decimal? @db.Decimal(18, 4)
  bbLower       Decimal? @db.Decimal(18, 4)
  updatedAt     DateTime @updatedAt
  stock         Stock    @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([stockId, date])
  @@index([stockId])
  @@index([date])
}

model Dividend {
  id            String    @id @default(cuid())
  stockId       String
  exDate        DateTime  @db.Date
  payDate       DateTime? @db.Date
  amount        Decimal   @db.Decimal(18, 4)
  currency      String    @default("KRW")
  dividendYield Decimal?  @db.Decimal(10, 4)
  payoutRatio   Decimal?  @db.Decimal(10, 4)
  faceValue     Decimal?  @db.Decimal(18, 4)
  source        String?
  stock         Stock     @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([stockId, exDate])
}

model Disclosure {
  id         String   @id @default(cuid())
  stockId    String
  rceptNo    String   @unique
  reportName String
  filerName  String?
  rceptDate  DateTime @db.Date
  remark     String?
  createdAt  DateTime @default(now())
  stock      Stock    @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@index([stockId, rceptDate])
  @@index([rceptDate])
}

model CronLog {
  id              String   @id @default(cuid())
  jobName         String
  status          String   // "success" | "error" | "partial"
  duration        Int      // ms
  itemsProcessed  Int?
  itemsFailed     Int?
  details         String?  @db.Text
  createdAt       DateTime @default(now())

  @@index([jobName])
  @@index([createdAt])
}

model EarningsEvent {
  id              String   @id @default(cuid())
  stockId         String
  reportDate      DateTime @db.Date
  quarter         String
  epsEstimate     Decimal? @db.Decimal(18, 4)
  epsActual       Decimal? @db.Decimal(18, 4)
  revenueEstimate BigInt?
  revenueActual   BigInt?
  updatedAt       DateTime @updatedAt
  stock           Stock    @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([stockId, quarter])
}

model AiReport {
  id           String   @id @default(cuid())
  slug         String   @unique
  stockId      String
  stock        Stock    @relation(fields: [stockId], references: [id], onDelete: Cascade)
  title        String   @db.Text
  signal       String
  content      String   @db.Text
  summary      String   @db.Text
  verdict      String
  reportDate   DateTime @db.Date
  dataSnapshot Json
  model        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([stockId, reportDate])
  @@index([createdAt])
  @@index([signal])
  @@index([stockId])
}
